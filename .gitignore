# Git worktrees
.worktrees/

# Superpowers harness state (per-machine, not project artifacts)
.superpowers/

# Drafts not yet meant for review (commit when ready)
docs/prds/
docs/requirements/
docs/review/

# NOTE: docs/superpowers/{specs,plans}/ is tracked.
# Per CLAUDE.md "project artifacts stay in the project", design specs and
# implementation plans produced by superpowers:brainstorming /
# writing-plans skills are project artifacts and must be committed.

# Local workspace metadata
AGENTS.md

# Local config file
.mcp.json

# Editor / agent extension caches (per-machine, not project artifacts)
.opencode/
.trae/

# Local skill/agent package fixtures used for manual upload testing.
# Contains binary .zip artifacts; not meant to live in git history.
source-test/

# Screenshots dropped at the repo root during debugging / design review.
# If a screenshot needs to live in the repo, put it under a deliberate
# directory like docs/diagnosis/ or docs/superpowers/specs/.
/*.png
