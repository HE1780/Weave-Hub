# ============================================================
# SkillHub 生产环境变量
# 使用方式: docker compose -f compose.release.yml --env-file .env up -d
# ============================================================

# ---- 镜像版本 ----
SKILLHUB_VERSION=latest
SKILLHUB_WEB_IMAGE=ghcr.io/iflytek/skillhub-web
SKILLHUB_SERVER_IMAGE=ghcr.io/iflytek/skillhub-server
SKILLHUB_SCANNER_IMAGE=ghcr.io/iflytek/skillhub-scanner

# ---- 域名 ----
SKILLHUB_PUBLIC_BASE_URL=https://skillhub.your-domain.com
DEVICE_AUTH_VERIFICATION_URI=https://skillhub.your-domain.com/cli/auth
SESSION_COOKIE_SECURE=true

# ---- 端口绑定（仅本地回环，由 OpenResty 反代对外）----
API_PORT=127.0.0.1:8080:8080
WEB_PORT=127.0.0.1:80:80
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND_ADDRESS=127.0.0.1
REDIS_PORT=6379

# ---- PostgreSQL (1Panel 直装则填实际连接信息，容器则用下面默认) ----
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=<生成一个强密码>

# ---- Redis ----
REDIS_IMAGE=redis:7-alpine

# ---- 阿里云 OSS (S3 兼容) ----
SKILLHUB_STORAGE_PROVIDER=s3
SKILLHUB_STORAGE_S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
SKILLHUB_STORAGE_S3_PUBLIC_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
SKILLHUB_STORAGE_S3_BUCKET=skillhub-prod
SKILLHUB_STORAGE_S3_ACCESS_KEY=<OSS AccessKey ID>
SKILLHUB_STORAGE_S3_SECRET_KEY=<OSS AccessKey Secret>
SKILLHUB_STORAGE_S3_REGION=oss-cn-hangzhou
SKILLHUB_STORAGE_S3_FORCE_PATH_STYLE=false
SKILLHUB_STORAGE_S3_AUTO_CREATE_BUCKET=false

# ---- 安全扫描 ----
SKILLHUB_SECURITY_SCANNER_ENABLED=true
SKILL_SCANNER_LLM_API_KEY=
SKILL_SCANNER_LLM_BASE_URL=
SKILL_SCANNER_LLM_MODEL=

# ---- GitHub OAuth ----
OAUTH2_GITHUB_CLIENT_ID=<GitHub OAuth App Client ID>
OAUTH2_GITHUB_CLIENT_SECRET=<GitHub OAuth App Client Secret>

# ---- 初始化管理员 ----
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USER_ID=admin
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=<生成一个强密码>
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin
BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.com

# ---- 邮件（密码重置，可选） ----
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_ENABLE=true
SKILLHUB_AUTH_PASSWORD_RESET_FROM_ADDRESS=noreply@your-domain.com
SKILLHUB_AUTH_PASSWORD_RESET_FROM_NAME=SkillHub
